{
  "manifest_version": 3,
  "name": "Medium Audience Stats",
  "version": "1.3.0",
  "description": "Enhanced analytics dashboard for Medium audience and earnings data, plus publication discovery and search.",
  "permissions": ["activeTab", "storage", "cookies"],
  "host_permissions": ["https://medium.com/*"],
  "action": {
    "default_title": "Medium Audience Stats"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://medium.com/me/audience*",
        "https://medium.com/me/stats*",
        "https://medium.com/me/partner/dashboard*"
      ],
      "js": ["content.js"],
      "css": ["dashboard.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "extractor.js",
        "dashboard.js",
        "lib/chart.umd.min.js",
        "lib/chartjs-adapter-date-fns.bundle.min.js"
      ],
      "matches": ["https://medium.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
